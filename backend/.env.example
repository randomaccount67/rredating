# Supabase — from dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# HMAC secret for email hashing — generate once with: openssl rand -hex 32
EMAIL_HMAC_SECRET=replace-with-random-32-byte-hex

# Tenor GIF API — get key at https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=

# Server
PORT=4000
NODE_ENV=development
# Comma-separated if you use both apex and www: https://rredating.com,https://www.rredating.com
FRONTEND_URL=http://localhost:3000
